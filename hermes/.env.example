# Base domain handled by Traefik. Hermes will be exposed at hermes.<DOMAIN>.
DOMAIN=example.com

# Bearer token required by the Hermes OpenAI-compatible API at /v1.
API_SERVER_KEY=replace-with-random-api-key

# Model name advertised by the Hermes API.
API_SERVER_MODEL_NAME=hermes-agent

# Dashboard basic auth credentials.
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=replace-with-strong-password

# Generate with: openssl rand -hex 32
HERMES_DASHBOARD_BASIC_AUTH_SECRET=replace-with-openssl-rand-hex-32
